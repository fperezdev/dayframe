# ─── API ──────────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Local dev (Neon):  postgresql://USER:PASSWORD@HOST/dayframe?sslmode=require
# Production (Neon): postgresql://USER:PASSWORD@HOST/dayframe?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/dayframe?sslmode=require"

# JWT secrets — use long random strings in production
JWT_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# Server port (Render sets this automatically; 3000 for local dev)
PORT=3000

# ─── Mobile ───────────────────────────────────────────────────────────────────

# Base URL of the NestJS API reachable from the device/emulator.
# Local dev:   http://localhost:3000  (or your machine's LAN IP for Expo Go)
# Production:  your Render service URL, e.g. https://dayframe-api.onrender.com
EXPO_PUBLIC_API_URL="http://localhost:3000"
